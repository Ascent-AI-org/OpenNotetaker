# Server
PORT=5173
HOST=0.0.0.0

# Providers. The compose file runs the web app with BOT_PROVIDER=fleet and separate
# worker containers; scale recordings with: docker compose up -d --scale open-notetaker-worker=3
BOT_PROVIDER=fleet
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_NORMALIZE_CHUNK_SIZE=18
GEMINI_RECONSTRUCT_CHUNK_SIZE=48
GEMINI_REQUEST_TIMEOUT_MS=90000
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
DEEPGRAM_KEYTERMS=Dhruv,OpenNotetaker,Google Meet,Deepgram,Whisper,Hinglish,PCs,pointers
DEEPGRAM_EXTRA_PARAMS=

# Runner callback auth. Replace with a long random value.
OPENNOTETAKER_BASE_URL=http://127.0.0.1:5173
RUNNER_TOKEN=replace-with-a-long-random-token
# Fleet job leasing: how long a worker claim survives without API activity, and how
# often idle workers poll for new jobs.
RUNNER_LEASE_SECONDS=120
RUNNER_POLL_SECONDS=5

# Browser inside the Linux container.
BOT_DISPLAY_NAME=OpenNotetaker - Recording
BOT_CHROME_EXECUTABLE_PATH=/usr/bin/chromium
BOT_CHROME_USER_DATA_DIR=/app/.bot-profile
BOT_CHROME_LAUNCH_MODE=rawcdp
BOT_CHROME_EXTRA_ARGS=--no-sandbox --disable-dev-shm-usage
BOT_HEADLESS=false
BOT_MAX_DURATION_MINUTES=120
BOT_ALONE_TIMEOUT_SECONDS=45

# Container PulseAudio loopback. No host audio driver is required.
FFMPEG_PATH=/usr/bin/ffmpeg
AUDIO_CAPTURE_DRIVER=pulse
AUDIO_CAPTURE_SOURCE=open_notetaker.monitor

# Gmail transcript delivery. GOOGLE_REDIRECT_URI must match the public VM URL registered in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5173/api/gmail/oauth/callback
GOOGLE_GMAIL_TOKEN_PATH=/app/data/google-gmail-token.json
# Comma-separated recipient list, e.g. you@example.com,sanya@example.com
TRANSCRIPT_EMAIL_TO=
TRANSCRIPT_EMAIL_FROM=
TRANSCRIPT_EMAIL_ENABLED=false

# Google Calendar read-only sync. Enable autostart only when the bot runner is ready to join meetings unattended.
GOOGLE_CALENDAR_SYNC_ENABLED=false
GOOGLE_CALENDAR_AUTOSTART_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_POLL_SECONDS=60
GOOGLE_CALENDAR_LOOKAHEAD_MINUTES=120
GOOGLE_CALENDAR_AUTOSTART_LEAD_MINUTES=2
GOOGLE_CALENDAR_AUTOSTART_LATE_MINUTES=30
GOOGLE_CALENDAR_RETENTION_DAYS=30
