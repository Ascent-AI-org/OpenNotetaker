# Server
PORT=5173
HOST=127.0.0.1

# Accounts and sessions. Sessions use HttpOnly cookies; secure cookies default on when
# OPENNOTETAKER_BASE_URL is https. Set AUTH_ALLOW_SIGNUPS=false to freeze signups.
AUTH_ALLOW_SIGNUPS=true
AUTH_SESSION_TTL_DAYS=14
AUTH_SECURE_COOKIES=

# LLM provider. Use "mock" for local development, or "gemini"/"openai" for real normalization/notes.
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_NORMALIZE_CHUNK_SIZE=18
GEMINI_RECONSTRUCT_CHUNK_SIZE=48
GEMINI_REQUEST_TIMEOUT_MS=90000

# Speech-to-text provider. The local MVP uses demo transcript simulation unless wired to a bot runner.
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
# Comma-separated hints for names, products, jargon, and recurring meeting terms.
# Keyterm prompting works with language=multi on nova-3 (Deepgram added multilingual
# keyterms in late 2025); keep the combined list under ~100 words.
DEEPGRAM_KEYTERMS=Dhruv,OpenNotetaker,Google Meet,Deepgram,Whisper,Hinglish,PCs,pointers
# Optional raw Deepgram query string for experiments. Overrides built-in defaults,
# for example: endpointing=500 (the built-in default is endpointing=300).
DEEPGRAM_EXTRA_PARAMS=

# Bot capture provider.
#   demo     - runs the Hinglish sample pipeline, no external services.
#   external - the web app spawns one runner child process per meeting (single-flight).
#   fleet    - recording workers claim jobs over the API; run `npm run bot:worker` per
#              worker (one concurrent recording each). Use this for multi-user setups.
BOT_PROVIDER=demo

# Runner/worker auth and job leasing. Required when BOT_PROVIDER=external or fleet.
OPENNOTETAKER_BASE_URL=http://127.0.0.1:5173
RUNNER_TOKEN=
# Fleet only: claim lease lifetime and worker poll cadence.
RUNNER_LEASE_SECONDS=120
RUNNER_POLL_SECONDS=5
# Fleet only: stable worker name in logs/events (defaults to hostname-pid).
WORKER_ID=
BOT_DISPLAY_NAME=OpenNotetaker - Recording
BOT_CHROME_CHANNEL=chrome
BOT_CHROME_EXECUTABLE_PATH=
BOT_CHROME_USER_DATA_DIR=.bot-profile
# direct, cdp, rawcdp, or applescript. Use rawcdp/applescript only for local prototyping.
BOT_CHROME_LAUNCH_MODE=rawcdp
BOT_CHROME_EXTRA_ARGS=
BOT_HEADLESS=false
BOT_MAX_DURATION_MINUTES=120
BOT_ALONE_TIMEOUT_SECONDS=45

# Audio capture for the external runner. Linux cloud runners should usually use PulseAudio.
FFMPEG_PATH=ffmpeg
AUDIO_CAPTURE_DRIVER=pulse
AUDIO_CAPTURE_SOURCE=default

# Gmail transcript delivery. Connect Gmail at /api/gmail/oauth/start after setting these.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5173/api/gmail/oauth/callback
GOOGLE_GMAIL_TOKEN_PATH=data/google-gmail-token.json
# Comma-separated recipient list, e.g. you@example.com,sanya@example.com
TRANSCRIPT_EMAIL_TO=
TRANSCRIPT_EMAIL_FROM=
# When false, use the dashboard "Send transcript" button on completed meetings.
TRANSCRIPT_EMAIL_ENABLED=false

# Google Calendar read-only sync. Enable autostart only when the bot runner is ready to join meetings unattended.
GOOGLE_CALENDAR_SYNC_ENABLED=false
GOOGLE_CALENDAR_AUTOSTART_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_POLL_SECONDS=60
GOOGLE_CALENDAR_LOOKAHEAD_MINUTES=120
GOOGLE_CALENDAR_AUTOSTART_LEAD_MINUTES=2
GOOGLE_CALENDAR_AUTOSTART_LATE_MINUTES=30
GOOGLE_CALENDAR_RETENTION_DAYS=30
