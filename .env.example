# ── OpenNotetaker configuration ──────────────────────────────────────────────
# One file, two run modes:
#
#   npm run dev            local demo — works with this file untouched (no keys)
#   docker compose up -d   real recordings — set the three REQUIRED values below
#
# Container-specific values (Chromium path, PulseAudio sink, internal URLs) are
# pinned inside docker-compose.yml, so nothing you set here for local development
# can break the containers.

# ── REQUIRED for real recordings (docker compose) ─────────────────────────────
# 1. Speech-to-text: https://console.deepgram.com → API key
DEEPGRAM_API_KEY=
# 2. Notes/normalization LLM: https://aistudio.google.com → API key
#    (or set LLM_PROVIDER=openai and OPENAI_API_KEY instead)
LLM_PROVIDER=mock
GEMINI_API_KEY=
# 3. Shared secret between the web app and recording workers.
#    Generate one: openssl rand -hex 32
RUNNER_TOKEN=

# ── OPTIONAL: Google integration (email delivery, calendar autojoin, login) ──
# Create an OAuth client in Google Cloud Console (see README → Google setup).
# Redirect URI must be <your base URL>/api/gmail/oauth/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5173/api/gmail/oauth/callback
GOOGLE_GMAIL_TOKEN_PATH=data/google-gmail-token.json

# Public base URL of the app. Behind a TLS proxy set https://... — this also turns
# secure cookies on. Workers in docker compose use the internal URL instead.
OPENNOTETAKER_BASE_URL=http://127.0.0.1:5173

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5173
HOST=127.0.0.1

# Accounts and sessions. Sessions use HttpOnly cookies; secure cookies default on
# when OPENNOTETAKER_BASE_URL is https. The first account to sign up becomes the
# admin. Set AUTH_ALLOW_SIGNUPS=false after your team is in (admins can still invite).
AUTH_ALLOW_SIGNUPS=true
AUTH_SESSION_TTL_DAYS=14
AUTH_SECURE_COOKIES=

# ── Speech-to-text tuning ─────────────────────────────────────────────────────
STT_PROVIDER=deepgram
DEEPGRAM_MODEL=nova-3
# "multi" is the whole point: code-switched Hindi-English in one stream.
DEEPGRAM_LANGUAGE=multi
# Comma-separated hints for names, products, and recurring jargon. Add your
# teammates' names — it noticeably improves Hinglish name recognition. Keyterm
# prompting works with language=multi on nova-3; keep the list under ~100 words.
DEEPGRAM_KEYTERMS=OpenNotetaker,Google Meet,Hinglish
# Optional raw Deepgram query string for experiments. Overrides built-in defaults,
# for example: endpointing=500 (the built-in default is endpointing=300).
DEEPGRAM_EXTRA_PARAMS=

# ── LLM tuning ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_NORMALIZE_CHUNK_SIZE=18
GEMINI_RECONSTRUCT_CHUNK_SIZE=48
GEMINI_REQUEST_TIMEOUT_MS=90000

# ── Bot capture provider ──────────────────────────────────────────────────────
#   demo     - runs the Hinglish sample pipeline, no external services.
#   external - the web app spawns one runner child process per meeting.
#   fleet    - recording workers claim jobs over the API (what docker compose runs;
#              scale with: docker compose up -d --scale open-notetaker-worker=3).
BOT_PROVIDER=demo

# Fleet job leasing: how long a worker claim survives without API activity, and how
# often idle workers poll for new jobs.
RUNNER_LEASE_SECONDS=120
RUNNER_POLL_SECONDS=5
# Stable worker name in logs/events (defaults to hostname-pid).
WORKER_ID=

# ── Bot browser (local development; docker-compose.yml pins its own values) ───
BOT_DISPLAY_NAME=OpenNotetaker - Recording
BOT_CHROME_CHANNEL=chrome
BOT_CHROME_EXECUTABLE_PATH=
BOT_CHROME_USER_DATA_DIR=.bot-profile
# direct, cdp, rawcdp, or applescript. Use rawcdp/applescript only for local prototyping.
BOT_CHROME_LAUNCH_MODE=rawcdp
BOT_CHROME_EXTRA_ARGS=
BOT_HEADLESS=false
BOT_MAX_DURATION_MINUTES=120
BOT_ALONE_TIMEOUT_SECONDS=45

# Audio capture for a local (non-docker) runner. Linux: pulse. macOS testing only:
# avfoundation with a loopback device.
FFMPEG_PATH=ffmpeg
AUDIO_CAPTURE_DRIVER=pulse
AUDIO_CAPTURE_SOURCE=default

# ── Transcript email delivery ─────────────────────────────────────────────────
# Recipients and auto-email are per-user settings in the UI; these are operator
# fallbacks for single-user/local use.
TRANSCRIPT_EMAIL_TO=
TRANSCRIPT_EMAIL_FROM=
TRANSCRIPT_EMAIL_ENABLED=false

# ── Google Calendar sync (operator switches; users opt in per account in the UI) ─
GOOGLE_CALENDAR_SYNC_ENABLED=false
GOOGLE_CALENDAR_AUTOSTART_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_POLL_SECONDS=60
GOOGLE_CALENDAR_LOOKAHEAD_MINUTES=120
GOOGLE_CALENDAR_AUTOSTART_LEAD_MINUTES=2
GOOGLE_CALENDAR_AUTOSTART_LATE_MINUTES=30
GOOGLE_CALENDAR_RETENTION_DAYS=30
